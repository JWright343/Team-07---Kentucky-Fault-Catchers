import threading
import time
import board
import neopixel

# -----------------------------
# LED SETUP
# -----------------------------
LED_COUNT = 12
LED_PIN = board.D18
BRIGHTNESS = 0.4

pixels = neopixel.NeoPixel(
    LED_PIN,
    LED_COUNT,
    brightness=BRIGHTNESS,
    auto_write=True,
    pixel_order=neopixel.GRB
)

# -----------------------------
# GLOBAL MODE VARIABLE
# -----------------------------
# 0 = OFF
# 1 = Red Pulse
# 2 = Rainbow
# 3 = Blue Pulse
mode = 0
running = True


# -----------------------------
# LIGHTING EFFECT FUNCTIONS
# -----------------------------
def effect_off():
    pixels.fill((0, 0, 0))


def effect_red_pulse():
    for b in range(0, 255, 5):
        pixels.fill((b, 0, 0))
        time.sleep(0.01)
    for b in range(255, 0, -5):
        pixels.fill((b, 0, 0))
        time.sleep(0.01)


def effect_rainbow():
    for j in range(255):
        for i in range(LED_COUNT):
            pixel_index = (i * 256 // LED_COUNT) + j
            pixels[i] = wheel(pixel_index & 255)
        time.sleep(0.01)


def effect_blue_pulse():
    for b in range(0, 255, 5):
        pixels.fill((0, 0, b))
        time.sleep(0.01)
    for b in range(255, 0, -5):
        pixels.fill((0, 0, b))
        time.sleep(0.01)



def wheel(pos):
    """Color helper for rainbow effect."""
    if pos < 85:
        return (pos * 3, 255 - pos * 3, 0)
    elif pos < 170:
        pos -= 85
        return (255 - pos * 3, 0, pos * 3)
    else:
        pos -= 170
        return (0, pos * 3, 255 - pos * 3)


# -----------------------------
# MAIN THREAD FUNCTION
# -----------------------------
def lighting_thread():
    global mode, running

    while running:
        if mode == 0:
            effect_off()
            time.sleep(0.1)

        elif mode == 1:
            effect_red_pulse()

        elif mode == 2:
            effect_rainbow()

        elif mode == 3:
            effect_blue_pulse()

        else:
            time.sleep(0.1)


# -----------------------------
# START THREAD
# -----------------------------
thread = threading.Thread(target=lighting_thread, daemon=True)
thread.start()


# -----------------------------
# EXAMPLE OF CHANGING MODES
# THIS IS WHERE THE MAIN FUNCTION WILL BE RUNNING INDEPENDENTLY OF THE INDICATION OPERATION
# wiLL NEED TO ADD MODE UPDATES THROUGHOUT OTHER FUNCTIONS TO INDICATE ERRORS/STATUSES
# -----------------------------
def main():
    try:
        print("Mode: OFF")
        time.sleep(2)

        print("Mode: Red Pulse")
        mode = 1
        time.sleep(5)

        print("Mode: Rainbow")
        mode = 2
        time.sleep(5)

        print("Mode: blue")
        mode = 3
        time.sleep(5)

        print("Back to OFF")
        mode = 0
        time.sleep(2)

    except KeyboardInterrupt:
        running = False
        thread.join()
        pixels.fill((0, 0, 0))
        print("Stopped.")

if __name__ == "__main__":
    main()

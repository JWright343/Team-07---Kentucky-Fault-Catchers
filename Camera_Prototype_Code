import requests
 
# --- Configures Camera ---

camera_ip = "169.254.217.104"        #Set IP address

snapshot_url = f"http://{camera_ip}/jpeg/vga.jpg"  # or /oneshotimage.jpg
 
# --- Requests Snapshot of Feed ---

response = requests.get(snapshot_url, timeout=5)
 
if response.status_code == 200:

    with open("snapshot.jpg", "wb") as f:

        f.write(response.content)

    print("Saved snapshot.jpg")

else:
    #Error condition if immage cannot be captured
    print("Error:", response.status_code, response.text)

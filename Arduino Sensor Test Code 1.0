/************************************************************
  TCS3200 + 74HC4067 Fault Flag Detection System
  Arduino Uno
************************************************************/

// ---------------- MUX PINS --------------------------
#define MUX_S0 6
#define MUX_S1 3
#define MUX_S2 4
#define MUX_S3 5
#define MUX_OUT 2 // Pin 2 will allow interrupt timing for the sensors, non-blocking

// ---------------- SENSOR CONTROL PINS ----------------
#define SENS_S0 7
#define SENS_S1 8
#define SENS_S2 9
#define SENS_S3 10

//----------------- LED PINS ----------------------------
#define RED_LED 11
#define GREEN_LED 12
#define BLUE_LED 13

// ---------------- GLOBAL VARIABLES ---------
volatile unsigned int pulseCount = 0; // For sensor interrupt counting
bool fciTrip = false;
bool catchAll = false;
// ---------------- CONSTANTS ----------------
//Timing variables to allow the LED to operate simultaneously with
//the sensors 
unsigned long previousMillis = 0; // Set timer to 0
const unsigned long INTERVAL = 500; // 0.5 second delay between LED states
bool flashState = false;

// ---------------- SETUP ----------------
void setup()
{
  Serial.begin(9600);

  pinMode(MUX_S0, OUTPUT);
  pinMode(MUX_S1, OUTPUT);
  pinMode(MUX_S2, OUTPUT);
  pinMode(MUX_S3, OUTPUT);
  pinMode(MUX_OUT, INPUT);

  //Rising edges on sensor reading increments pulseCount
  attachInterrupt(digitalPinToInterrupt(MUX_OUT), pulseISR, RISING);

  pinMode(SENS_S0, OUTPUT);
  pinMode(SENS_S1, OUTPUT);
  pinMode(SENS_S2, OUTPUT);
  pinMode(SENS_S3, OUTPUT);

  pinMode(RED_LED, OUTPUT);
  pinMode(GREEN_LED, OUTPUT);
  pinMode(BLUE_LED, OUTPUT);

  // Sensor frequency scaling = 100%
  digitalWrite(SENS_S0, HIGH);
  digitalWrite(SENS_S1, HIGH);

  Serial.println("System Initialized");
  Serial.println("------------------");
}

//Function to help with the sensor interrupts
void pulseISR(){
  pulseCount++;
}

// ---------------- MUX CHANNEL SELECT ----------------
void selectChannel(int ch)
{
  digitalWrite(MUX_S0, ch & 1);
  digitalWrite(MUX_S1, (ch >> 1) & 1);
  digitalWrite(MUX_S2, (ch >> 2) & 1);
  digitalWrite(MUX_S3, (ch >> 3) & 1);
  delayMicroseconds(200);
}

// ---------------- READ PULSE ----------------
unsigned int readFrequency(unsigned int sampleTimeMs)
{
  //Reset counter safely
  noInterrupts(); //Turns off interrupt flag
  pulseCount = 0;
  interrupts(); // Turns interrupt flag back on
  
  unsigned long start = millis();
  while(millis() - start < sampleTimeMs) {
    // just wait, interrupts will count pulses
  }

  // Copy result safely
  noInterrupts();
  unsigned int count = pulseCount;
  interrupts();

  return pulseCount;
}


// ---------------- READ ONE SENSOR ----------------
bool readSensor(int ch, int &R, int &B, int &G)
{
  selectChannel(ch);

  // RED
  digitalWrite(SENS_S2, LOW);
  digitalWrite(SENS_S3, LOW);
  delayMicroseconds(200); // Allow filter to settle
  R = readFrequency(20);

  // BLUE
  digitalWrite(SENS_S2, LOW);
  digitalWrite(SENS_S3, HIGH);
  delayMicroseconds(200); 
  B = readFrequency(20);

  // Green: This, with the blue filter, should provide a more accurate red reading
  digitalWrite(SENS_S2, HIGH);
  digitalWrite(SENS_S3, HIGH);
  delayMicroseconds(200); 
  G = readFrequency(20);

  // Health check
  if(R == 0 && B == 0 && G == 0) return false;
  
  return true;
}

// ---------------- RED FLAG DETECTION ----------------
bool isRedFlag(int R, int B, int G) //Normalize the red detection
{
  float sum = R + G + B;
  if(sum == 0)
    return false;

  float rRatio = R / sum;

  return rRatio > 0.5; //Can tune this value
}

// ----------------- LED Operation Code ---------------
void updateLED(bool fciTrip, bool catchAll) {
  unsigned long now = millis();

  if(catchAll) {
    // Magenta = Red + Blue. This is for any other fault found in testing
    digitalWrite(RED_LED, HIGH);
    digitalWrite(GREEN_LED, LOW);
    digitalWrite(BLUE_LED, HIGH);
  } 
  else if(fciTrip) {
    // Flashing red
    if(now - previousMillis >= INTERVAL) {
      previousMillis = now;
      flashState = !flashState;
      digitalWrite(RED_LED, flashState ? HIGH : LOW); //flashState allows blinking
      digitalWrite(GREEN_LED, LOW);
      digitalWrite(BLUE_LED, LOW);
    }
  } 
  else {
    // All normal → solid blue
    digitalWrite(RED_LED, LOW);
    digitalWrite(GREEN_LED, LOW);
    digitalWrite(BLUE_LED, HIGH);
  }
}

// ---------------- MAIN LOOP ----------------
void loop()
{
    for(int ch = 0; ch < 16; ch++)
  {
    int R, B, G;

    if(!readSensor(ch, R, B, G))
    {
      Serial.print("Sensor ");
      Serial.print(ch);
      Serial.println(": DISCONNECTED / FAULT");
      continue;
    }

    Serial.print("Sensor ");
    Serial.print(ch);
    Serial.print("  R=");
    Serial.print(R);
    Serial.print(" B=");
    Serial.print(B);
    Serial.print(" G=");
    Serial.print(G);
    Serial.print("  --> ");

    if(isRedFlag(R, B, G)){
      fciTrip = true;
      Serial.println("FAULT FLAG");
    }
    // This while loop will keep the Arduino stuck on the tripped sensor 
    // until it is back to normal 
      while(isRedFlag(R, B, G)){
        readSensor(ch, R, B, G);
        if (isRedFlag(R, B, G)){
          updateLED(fciTrip, catchAll);
        }      
        else{
          fciTrip = false;
          updateLED(fciTrip, catchAll);
        }
     }
    else{
      Serial.println("NORMAL");
      // Do LED code here
    }


    
  updateLED(fciTrip, catchAll);
  Serial.println("------------------");
  delay(5);
  }
}
